
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Garnet Fund — University of South Carolina</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Mono:wght@300;400;500&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --garnet: #73000a;
    --garnet-deep: #4a0006;
    --garnet-light: #9a0010;
    --garnet-mist: #f5e8ea;
    --gold: #c49a22;
    --gold-light: #e8c84a;
    --cream: #faf8f4;
    --ink: #0e0d0c;
    --ink-60: rgba(14,13,12,0.6);
    --ink-30: rgba(14,13,12,0.3);
    --ink-10: rgba(14,13,12,0.08);
    --white: #ffffff;
    --rule: rgba(14,13,12,0.12);
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Syne', sans-serif;
    --font-mono: 'DM Mono', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--cream);
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(250,248,244,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .nav-logo-mark {
    width: 32px;
    height: 32px;
    background: var(--garnet);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.5px;
  }

  .nav-logo-text {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-60);
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--garnet); }

  .nav-cta {
    background: var(--garnet) !important;
    color: #fff !important;
    padding: 8px 20px;
    font-size: 11px !important;
    letter-spacing: 0.12em !important;
  }

  .nav-cta:hover { background: var(--garnet-deep) !important; color: #fff !important; }

  /* ── HERO ── */
  #hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 64px;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    padding: 80px 48px 80px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--garnet);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 32px;
    height: 1px;
    background: var(--garnet);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 6vw, 88px);
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -1px;
    color: var(--ink);
    margin-bottom: 32px;
  }

  .hero-title em {
    font-style: italic;
    color: var(--garnet);
  }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 400;
    color: var(--ink-60);
    line-height: 1.7;
    max-width: 400px;
    margin-bottom: 48px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .btn-primary {
    background: var(--garnet);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 32px;
    text-decoration: none;
    transition: background 0.2s;
    display: inline-block;
  }

  .btn-primary:hover { background: var(--garnet-deep); }

  .btn-ghost {
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid var(--ink-30);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-ghost:hover { color: var(--garnet); border-color: var(--garnet); }

  .hero-right {
    background: var(--garnet);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 60px 64px;
    overflow: hidden;
  }

  .hero-right::before {
    content: 'G';
    position: absolute;
    top: -60px;
    right: -40px;
    font-family: var(--font-display);
    font-size: 480px;
    font-weight: 600;
    color: rgba(255,255,255,0.04);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.12);
  }

  .hero-stat {
    background: var(--garnet);
    padding: 32px 28px;
  }

  .hero-stat-num {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 500;
    color: #fff;
    line-height: 1;
    margin-bottom: 8px;
  }

  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    font-weight: 400;
    color: rgba(255,255,255,0.7);
    margin-bottom: 40px;
    line-height: 1.4;
  }

  /* ── SECTION BASE ── */
  section {
    padding: 100px 80px;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--garnet);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-label::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--garnet);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 58px);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.5px;
    margin-bottom: 24px;
  }

  .section-title em {
    font-style: italic;
    color: var(--garnet);
  }

  /* ── TICKER ── */
  .ticker-bar {
    background: var(--ink);
    color: rgba(255,255,255,0.5);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 10px 0;
    overflow: hidden;
    white-space: nowrap;
  }

  .ticker-inner {
    display: inline-block;
    animation: ticker 30s linear infinite;
  }

  .ticker-inner span {
    margin: 0 48px;
  }

  .ticker-inner span.up { color: #4ade80; }
  .ticker-inner span.down { color: #f87171; }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ── APPROACH ── */
  #approach {
    background: var(--white);
    padding: 100px 80px;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-top: 64px;
    align-items: start;
  }

  .approach-left {}

  .approach-intro {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--ink);
    margin-bottom: 32px;
  }

  .approach-body {
    font-size: 14px;
    color: var(--ink-60);
    line-height: 1.8;
    margin-bottom: 40px;
  }

  .approach-pillars {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pillar {
    padding: 28px 0;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 20px;
    align-items: start;
    cursor: default;
    transition: background 0.2s;
  }

  .pillar:last-child { border-bottom: 1px solid var(--rule); }

  .pillar-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--garnet);
    padding-top: 3px;
  }

  .pillar-content h4 {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 8px;
    color: var(--ink);
  }

  .pillar-content p {
    font-size: 13px;
    color: var(--ink-60);
    line-height: 1.7;
  }

  /* strategy cards right side */
  .strategy-cards {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .strategy-card {
    background: var(--garnet);
    padding: 36px 40px;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .strategy-card:nth-child(2) { background: var(--garnet-deep); }
  .strategy-card:nth-child(3) { background: var(--ink); }

  .strategy-card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 12px;
  }

  .strategy-card-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 500;
    font-style: italic;
    line-height: 1.2;
    margin-bottom: 12px;
    color: #fff;
  }

  .strategy-card-desc {
    font-size: 13px;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }

  .strategy-card-icon {
    position: absolute;
    right: 32px;
    bottom: 20px;
    font-family: var(--font-display);
    font-size: 80px;
    color: rgba(255,255,255,0.05);
    line-height: 1;
    font-style: italic;
    pointer-events: none;
  }

  /* ── DIVIDER ── */
  .full-bleed-quote {
    background: var(--garnet-deep);
    padding: 80px 80px;
    text-align: center;
  }

  .full-bleed-quote blockquote {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 400;
    font-style: italic;
    color: rgba(255,255,255,0.9);
    line-height: 1.3;
    max-width: 900px;
    margin: 0 auto 24px;
  }

  .full-bleed-quote cite {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    font-style: normal;
  }

  /* ── TEAM ── */
  #team {
    padding: 100px 80px;
  }

  .team-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    margin-bottom: 64px;
    align-items: end;
  }

  .team-intro {
    font-size: 14px;
    color: var(--ink-60);
    line-height: 1.8;
  }

  .leadership-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-bottom: 2px;
  }

  .member-card {
    background: var(--white);
    padding: 28px 24px;
    border: 1px solid var(--rule);
    position: relative;
    transition: border-color 0.2s;
  }

  .member-card:hover { border-color: var(--garnet); }

  .member-initial {
    width: 48px;
    height: 48px;
    background: var(--garnet-mist);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    color: var(--garnet);
    margin-bottom: 20px;
  }

  .member-name {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
    letter-spacing: 0.02em;
  }

  .member-role {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--garnet);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .member-year {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-30);
    letter-spacing: 0.06em;
  }

  .analysts-section {
    margin-top: 48px;
  }

  .analysts-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--rule);
  }

  .analysts-title {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .sector-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .sector-tab {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    padding: 5px 12px;
    border: 1px solid var(--rule);
    color: var(--ink-60);
    cursor: pointer;
    transition: all 0.15s;
    background: transparent;
    user-select: none;
  }

  .sector-tab:hover, .sector-tab.active {
    background: var(--garnet);
    border-color: var(--garnet);
    color: #fff;
  }

  .analysts-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
  }

  .analyst-card {
    background: var(--white);
    padding: 20px 18px;
    border: 1px solid var(--rule);
  }

  .analyst-name {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 3px;
  }

  .analyst-sector {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-30);
    letter-spacing: 0.06em;
  }

  .analyst-role-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 7px;
    background: var(--garnet-mist);
    color: var(--garnet);
    margin-top: 6px;
  }

  /* ── JOIN ── */
  #join {
    background: var(--ink);
    padding: 100px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  #join .section-label { color: rgba(255,255,255,0.35); }
  #join .section-label::before { background: rgba(255,255,255,0.35); }

  #join .section-title { color: #fff; }

  .join-body {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.8;
    margin-bottom: 40px;
  }

  .join-cta {
    background: #fff;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 36px;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s;
  }

  .join-cta:hover { background: var(--garnet-mist); }

  .join-right {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .join-step {
    padding: 28px 32px;
    border: 1px solid rgba(255,255,255,0.08);
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 20px;
    align-items: start;
  }

  .join-step-num {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 400;
    color: var(--garnet);
    line-height: 1;
  }

  .join-step h4 {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-bottom: 6px;
  }

  .join-step p {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
  }

  /* ── DONATE ── */
  #donate {
    padding: 100px 80px;
    background: var(--white);
  }

  .donate-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    margin-top: 64px;
    align-items: start;
  }

  .donate-body {
    font-size: 14px;
    color: var(--ink-60);
    line-height: 1.8;
    margin-bottom: 32px;
  }

  .donate-milestone {
    background: var(--garnet-mist);
    border-left: 3px solid var(--garnet);
    padding: 24px 28px;
    margin-bottom: 32px;
  }

  .donate-milestone p {
    font-size: 13px;
    color: var(--ink);
    line-height: 1.7;
  }

  .donate-milestone strong {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 500;
    display: block;
    margin-bottom: 8px;
    color: var(--garnet);
  }

  .donate-btn {
    background: var(--garnet);
    color: #fff;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 36px;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s;
  }

  .donate-btn:hover { background: var(--garnet-deep); }

  .transparency-cards {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .transparency-card {
    background: var(--cream);
    padding: 32px;
    display: flex;
    gap: 24px;
    align-items: flex-start;
    border: 1px solid var(--rule);
  }

  .tc-freq {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--garnet);
    padding: 4px 10px;
    min-width: 76px;
    text-align: center;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .tc-body h4 {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
  }

  .tc-body p {
    font-size: 12px;
    color: var(--ink-60);
    line-height: 1.6;
  }

  /* ── CONTACT / FOOTER ── */
  footer {
    background: var(--garnet-deep);
    padding: 60px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-logo {
    display: flex;
